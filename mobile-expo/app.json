{
  "expo": {
    "name": "APEXIS",
    "slug": "apexis",
    "version": "1.3.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "apexis",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apexis.ios",
      "buildNumber": "8",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "APEXIS needs access to your photo library to attach photos to snags and upload site images.",
        "NSPhotoLibraryAddUsageDescription": "APEXIS needs permission to save downloaded photos to your library.",
        "NSCameraUsageDescription": "APEXIS needs camera access to capture site photos.",
        "NSMicrophoneUsageDescription": "APEXIS needs microphone access for video capture."
      }
    },
    "android": {
      "package": "com.apexis.app",
      "versionCode": 8,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.ACCESS_MEDIA_LOCATION",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.POST_NOTIFICATIONS"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-notifications",
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      [
        "expo-image-picker",
        {
          "photosPermission": "APEXIS needs access to your photos to attach images to snags and upload site photos.",
          "cameraPermission": "APEXIS needs camera access to capture site photos."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "APEXIS needs access to your photo library.",
          "savePhotosPermission": "APEXIS needs permission to save photos to your library.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "APEXIS needs camera access to scan documents."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a496b666-bbb8-48a7-920b-08d20af0d60f"
      }
    }
  }
}